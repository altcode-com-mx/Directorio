rules_version = '2';

// Despliega en Firebase Console → Firestore → Reglas, o: firebase deploy --only firestore:rules
// Sin request.auth, nadie debe poder leer ni escribir `clientes` desde clientes no autenticados.

service cloud.firestore {
  match /databases/{database}/documents {
    match /clientes/{docId} {
      allow read, create, update, delete: if request.auth != null;
    }
  }
}
